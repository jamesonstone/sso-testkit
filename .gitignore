# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# ----------------------------------------------------------------------------
# Scenario safety conventions (prevent accidental commit of live test data)
#
# Commit only sanitized templates under configs/scenarios, using:
#   *-template.yaml
#
# Keep local/live variants out of git, using:
#   *-local.yaml / *-dev.yaml / *-stage.yaml / *-staging.yaml / *-prod.yaml / *-live.yaml
#
# NOTE: Existing files like oidc-token-exchange.yaml may still be tracked if already
# committed. Prefer creating and committing a corresponding *-template.yaml and use
# ignored environment-specific copies for real credentials/endpoints.
# ----------------------------------------------------------------------------
configs/scenarios/*-local.yaml
configs/scenarios/*-dev.yaml
configs/scenarios/*-stage.yaml
configs/scenarios/*-staging.yaml
configs/scenarios/*-prod.yaml
configs/scenarios/*-live.yaml
configs/scenarios/*-private.yaml

# Editor/IDE
# .idea/
# .vscode/

# Kit local generated environment, cache, and scratch artifacts
.envrc
.kit/runs/
.kit/loops/
.kit/state.json
.kit/cache/
.kit/tmp/
.kit/temp/
.kit/*.tmp
.kit/*.lock
